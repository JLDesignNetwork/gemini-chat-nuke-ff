{
  "manifest_version": 3,
  "name": "Gemini Chat Nuke",
  "short_name": "Gemini Nuke",
  "description": "Bulk delete Gemini conversations with injected UI.\n\n*Note: Theoretical minimum version is 109.0, but only tested on 152.0+*",
  "default_locale": "en",
  "version": "1.1",
  "author": "Jeff Langdon",
  "homepage_url": "https://github.com/JLDesignNetwork/gemini-chat-nuke-ff",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "96": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    },
    "default_title": "Gemini Chat Nuke"
  },
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gemini-chat-nuke@your-email-or-domain.com",
      "strict_min_version": "152.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "incognito": "spanning"
}